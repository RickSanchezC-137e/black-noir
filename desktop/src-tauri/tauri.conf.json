{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noir",
  "version": "0.2.0",
  "identifier": "org.noir.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "label": "main", "title": "Black Noir", "decorations": false,
        "width": 1280, "height": 800, "minWidth": 1024, "minHeight": 640,
        "resizable": true, "maximizable": true, "minimizable": true, "fullscreen": false,
        "center": true }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper" } }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/RickSanchezC-137e/black-noir/releases/latest/download/latest.json"],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxNDJGMzdFMDg5NkI5RDIKUldUU3VaWUlmdk5DMFJGU2ZBWGQ1YkRWWXpQekRqZkdXZTZTeVFhOXREaTRSb052TXFCcHF3TWwK"
    }
  }
}
