# Caddy reverse proxy для Black Noir. Ядро noir-core слушает localhost:8000.
#  • jarvisgod.duckdns.org — НАСТОЯЩИЙ Let's Encrypt cert (домен -> 89.208.97.41, 80/443 открыты).
#    Десктоп-клиент ходит сюда (доверенный TLS). Токен DuckDNS не нужен (IP статический).
#  • 89.208.97.41 — голый IP, самоподписанный cert (tls internal), для прямого доступа.
#  Авторизация владельца теперь в самом приложении (cookie-сессия ядра, Fallout-форма),
#  поэтому basic_auth убран — нативное окно браузера больше не всплывает.

jarvisgod.duckdns.org {
	@no_ua {
		not header User-Agent *
	}
	respond @no_ua "Forbidden" 403 {
		close
	}
	@bad_agents header_regexp User-Agent (?i)(nikto|sqlmap|nmap|masscan|zgrab|nuclei|fimap|dirbuster|gobuster|wpscan|petalbot|semrushbot|ahrefsbot|mj12bot|dotbot|bytespider|censys|zoominfobot)
	respond @bad_agents "Forbidden" 403 {
		close
	}
	@probe_paths path /.env /.git/* /wp-admin* /wp-login.php /phpmyadmin* /.aws/* /vendor/* /xmlrpc.php
	respond @probe_paths "Not Found" 404 {
		close
	}
	reverse_proxy localhost:8000
}

89.208.97.41 {
	tls internal
	@no_ua2 {
		not header User-Agent *
	}
	respond @no_ua2 "Forbidden" 403 {
		close
	}
	reverse_proxy localhost:8000
}
