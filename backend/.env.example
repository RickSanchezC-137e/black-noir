# Noir core — environment template (NO real values here). Real values live in secrets/.env (outside git).
# Procedure: backup old secrets FIRST (done), then copy values into secrets/.env. Never invent secrets.

# --- Project identity (rename-friendly, CANON §14) — ONE source of the name ---
PROJECT_NAME=Black Noir

# --- LLM (brain) ---
ANTHROPIC_API_KEY=          # <<TAKE_FROM_OLD_PROJECT>> (backed up)
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_CODE_BIN=claude       # headless Claude Code CLI (Builder)
LLM_MAX_TOKENS=4096

# --- Search ---
TAVILY_API_KEY=             # <<TAKE_FROM_OLD_PROJECT>>

# --- Telegram (C1 notifications / escalations) ---
TELEGRAM_BOT_TOKEN=         # <<TAKE_FROM_OLD_PROJECT>>
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_NOTIFY_SECRET=

# --- GitHub (release/update channel) ---
GITHUB_TOKEN=               # <<TAKE_FROM_OLD_PROJECT>>

# --- Network / deploy (core on VPS-01) ---
PUBLIC_DOMAIN=jarvisgod.duckdns.org
DUCKDNS_TOKEN=              # <<TAKE_FROM_OLD_PROJECT>> (MISSING on host — request from owner)
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=

# --- Data paths (absolute on prod) ---
DATA_DIR=./data
SQLITE_PATH=./data/noir.sqlite
CHROMA_DIR=./data/chroma
VOICES_DIR=./secrets/voices

# --- Memory / embeddings (CANON: local all-MiniLM-L6-v2, dim=384) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Voice ---
WHISPER_MODEL=base           # faster-whisper: tiny|base|small|medium (CPU here)
WHISPER_DEVICE=auto          # auto -> cpu (no GPU on VPS-01)
PIPER_VOICE=ru_RU-dmitri-medium.onnx
